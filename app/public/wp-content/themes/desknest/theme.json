{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{ "slug": "page-background", "color": "#F6F7F4", "name": "Page background" },
				{ "slug": "surface", "color": "#FFFFFF", "name": "Surface" },
				{ "slug": "subtle-surface", "color": "#ECEFEB", "name": "Subtle surface" },
				{ "slug": "primary-text", "color": "#18211D", "name": "Primary text" },
				{ "slug": "secondary-text", "color": "#59645E", "name": "Secondary text" },
				{ "slug": "border", "color": "#D7DDD9", "name": "Border" },
				{ "slug": "accent", "color": "#2F6F5E", "name": "Accent" },
				{ "slug": "accent-dark", "color": "#245548", "name": "Accent dark" },
				{ "slug": "success", "color": "#2F7A49", "name": "Success" },
				{ "slug": "warning", "color": "#9A6108", "name": "Warning" },
				{ "slug": "error", "color": "#B13B3B", "name": "Error" },
				{ "slug": "information", "color": "#326B8A", "name": "Information" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"slug": "system",
					"name": "System sans-serif",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif"
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Small" },
				{ "slug": "body", "size": "1rem", "name": "Body" },
				{ "slug": "lead", "size": "1.125rem", "name": "Lead" },
				{ "slug": "heading-4", "size": "1.25rem", "name": "Heading 4" },
				{ "slug": "heading-3", "size": "1.5rem", "name": "Heading 3" },
				{ "slug": "heading-2", "size": "2rem", "name": "Heading 2" },
				{ "slug": "heading-1", "size": "2.75rem", "name": "Heading 1" }
			]
		},
		"spacing": {
			"spacingSizes": [
				{ "slug": "10", "size": "4px", "name": "1" },
				{ "slug": "20", "size": "8px", "name": "2" },
				{ "slug": "30", "size": "12px", "name": "3" },
				{ "slug": "40", "size": "16px", "name": "4" },
				{ "slug": "50", "size": "24px", "name": "5" },
				{ "slug": "60", "size": "32px", "name": "6" },
				{ "slug": "70", "size": "48px", "name": "7" },
				{ "slug": "80", "size": "64px", "name": "8" },
				{ "slug": "90", "size": "96px", "name": "9" }
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1280px"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--page-background)",
			"text": "var(--wp--preset--color--primary-text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--body)"
		}
	}
}
